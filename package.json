{
  "name": "global-conflict-monitor",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild": "npx tsx scripts/validate-env.ts && npx tsx scripts/migrate.ts",
    "start": "next start",
    "validate-env": "npx tsx scripts/validate-env.ts",
    "db:migrate": "npx tsx scripts/migrate.ts",
