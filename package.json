    "@types/twilio": "^3.18.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/pg": "^8.11.6",
    "@types/nodemailer": "^6.4.14",
    "typescript": "^5",
    "tsx": "^4.16.2",
    "tailwindcss": "^3.4.4",
    "autoprefixer": "^10.4.19",
