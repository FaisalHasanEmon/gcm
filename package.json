    "migrate": "npx tsx scripts/migrate.ts",
    "seed": "npx tsx scripts/seed.ts",
    "register-webhook": "npx tsx scripts/register-telegram-webhook.ts",
    "ingest": "npx tsx workers/ingest.ts",
    "brief": "npx tsx workers/brief.ts",
    "alerts:hourly": "npx tsx workers/alerts.ts hourly",
    "alerts:daily": "npx tsx workers/alerts.ts daily",
